{
  "name": "softwarefreemp3",
  "version": "1.4.10",
  "description": "Aplicacion de escritorio para descargar de multimedia de paginas webs como youtube",
  "main": "electron/main.js",
  "scripts": {
    "dev:web": "node src/server.js",
    "dev": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.softwarefreemp3.app",
    "productName": "SoftwareFreeMP3",
    "icon": "build/icon.ico",

    "publish": [
      {
        "provider": "github",
        "owner": "Jean-Pierre001",
        "repo": "SoftwareFreeMp3"
      }
    ],

    "directories": {
      "output": "dist"
    },

    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "src/bin",
        "to": "bin"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg/ffmpeg.exe"
      }
    ],

    "win": {
      "target": "nsis"
    },

    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  }
}